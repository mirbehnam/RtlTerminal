<Window x:Class="RtlTerminal.FontSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Font settings"
        Icon="RtlTerminal.ico"
        Width="640"
        Height="540"
        MinWidth="540"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#f4f5f7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Terminal font"
                   FontSize="23"
                   FontWeight="SemiBold"
                   Foreground="#182033"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="135" />
            </Grid.ColumnDefinitions>

            <TabControl Margin="0,0,14,0">
                <TabItem Header="Standard fonts">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="2,0,2,8"
                                   Foreground="#586174"
                                   TextWrapping="Wrap"
                                   Text="Recommended fonts for CMD, PowerShell, terminals and coding that are installed on this Windows." />
                        <ListBox x:Name="StandardFontListBox"
                                 SelectionChanged="StandardFontListBox_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </DockPanel>
                </TabItem>
                <TabItem Header="All installed fonts">
                    <DockPanel Margin="8">
                        <TextBox x:Name="FontSearchTextBox"
                                 DockPanel.Dock="Top"
                                 Margin="0,0,0,8"
                                 Padding="7"
                                 TextChanged="FontSearchTextBox_TextChanged" />
                        <ListBox x:Name="FontListBox"
                                 SelectionChanged="FontListBox_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </DockPanel>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Size"
                           Margin="0,0,0,5" />
                <ComboBox x:Name="FontSizeComboBox"
                          IsEditable="True"
                          SelectionChanged="FontOption_Changed"
                          TextBoxBase.TextChanged="FontOption_Changed">
                    <ComboBoxItem Content="8" />
                    <ComboBoxItem Content="9" />
                    <ComboBoxItem Content="10" />
                    <ComboBoxItem Content="11" />
                    <ComboBoxItem Content="12" />
                    <ComboBoxItem Content="14" />
                    <ComboBoxItem Content="15" />
                    <ComboBoxItem Content="16" />
                    <ComboBoxItem Content="18" />
                    <ComboBoxItem Content="20" />
                    <ComboBoxItem Content="22" />
                    <ComboBoxItem Content="24" />
                    <ComboBoxItem Content="28" />
                    <ComboBoxItem Content="32" />
                    <ComboBoxItem Content="36" />
                    <ComboBoxItem Content="48" />
                </ComboBox>

                <CheckBox x:Name="BoldCheckBox"
                          Content="Bold"
                          Margin="0,18,0,8"
                          Checked="FontOption_Changed"
                          Unchecked="FontOption_Changed" />
                <CheckBox x:Name="ItalicCheckBox"
                          Content="Italic"
                          Checked="FontOption_Changed"
                          Unchecked="FontOption_Changed" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#10151f"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,16">
            <TextBlock x:Name="PreviewTextBlock"
                       Foreground="#e6e6e6"
                       TextWrapping="Wrap"
                       Text="Rtl Terminal  |  ترمینال فارسی  |  1234567890&#x0a;https://behnamapps.example" />
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="90"
                    Margin="0,0,8,0"
                    Padding="8,5"
                    Content="Cancel"
                    IsCancel="True" />
            <Button Width="90"
                    Padding="8,5"
                    Content="Apply"
                    IsDefault="True"
                    Click="ApplyButton_Click" />
        </StackPanel>
    </Grid>
</Window>
